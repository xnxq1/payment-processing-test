APP_NAME=payment-processing
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
JSON_LOGS=true
PYTHONUNBUFFERED=1

# API auth
API_KEY=local-dev-api-key

# Webhook
WEBHOOK_SECRET=local-dev-webhook-secret
WEBHOOK_TIMEOUT_SECONDS=5

# Postgres
POSTGRES_DB=payments
POSTGRES_USER=payments
POSTGRES_PASSWORD=payments
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=payments
CONSUMER_PREFETCH=10

# Routing keys / queue names
QUEUE_PAYMENTS_NEW=payments.new
QUEUE_PAYMENTS_RETRY=payments.new.retry
QUEUE_PAYMENTS_DLQ=payments.new.dlq

# Processing
PAYMENT_PROCESSING_MIN_SECONDS=2
PAYMENT_PROCESSING_MAX_SECONDS=5
PAYMENT_SUCCESS_RATE=0.9
PAYMENT_MAX_RETRIES=3

# Outbox
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_BATCH_SIZE=50
